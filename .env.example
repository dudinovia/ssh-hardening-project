# @file .env.example
# @brief Шаблон переменных окружения для SSH Hardening проекта
# @version 1.0.0

# ==============================================================================
# НАСТРОЙКИ SSH СЕРВЕРА
# ==============================================================================

# Порт SSH 
SSH_PORT=2222

# Таймаут аутентификации (секунды)
SSH_LOGIN_GRACE_TIME=30

# ==============================================================================
# MFA (Двухфакторная аутентификация) - ОПЦИОНАЛЬНО
# ==============================================================================

# Включить MFA (true/false)
MFA_ENABLED=true

# Секрет для Google Authenticator (генерируется автоматически)
# MFA_SECRET=

# ==============================================================================
# БЕЗОПАСНОСТЬ
# ==============================================================================

# Разрешённые пользователи для SSH доступа
ALLOW_USERS=admin,deploy

# Разрешённые группы
ALLOW_GROUPS=ssh-users,admin

# ==============================================================================
# МОНТОРИНГ
# ==============================================================================

# Порт Prometheus
PROMETHEUS_PORT=9090

# Порт Grafana
GRAFANA_PORT=3000
